{
  "name": "@dm-broo/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "build": "bun build src/index.ts --outdir dist --outfile dist/index.js --target bun --minify --packages external",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.66.4",
    "express": "^4.18.2",
    "ioredis": "^5.9.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bun": "latest",
    "prisma": "^6.19.0",
    "typescript": "^5"
  }
}