{
  "name": "@dm-broo/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "build": "bun build src/index.ts --outdir dist --outfile dist/index.js --target bun --minify --packages external",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.66.4",
    "ioredis": "^5.9.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.0",
    "typescript": "^5"
  }
}
