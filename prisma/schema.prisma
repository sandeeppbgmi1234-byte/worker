generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  clerkId       String         @unique
  fullName      String
  email         String         @unique
  imageUrl      String?
  createdAt     DateTime       @default(now())
  instaAccounts InstaAccount[]
  subscription  Subscription?
  creditLedger  CreditLedger?

  @@map("users")
}

model InstaAccount {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Instagram account details
  instagramUserId   String  @unique //  // Instagram User ID (for API calls)
  webhookUserId     String? @unique // Instagram Business Account ID (for webhooks)
  username          String
  profilePictureUrl String?
  biography         String?
  followersCount    Int?
  followsCount      Int?
  mediaCount        Int?
  accountType       String? // BUSINESS, CREATOR, PERSONAL

  // OAuth tokens (encrypted in production)
  accessToken    String   @default("")
  refreshToken   String?
  tokenExpiresAt DateTime @default(now())
  grantedScopes  String[] @default([])

  // Facebook Page (required for messaging)
  // facebookPageId   String?
  // facebookPageName String?

  // Connection metadata
  connectedAt            DateTime                @default(now())
  lastSyncedAt           DateTime                @default(now())
  webhooksEnabled        Boolean                 @default(false)
  isActive               Boolean                 @default(true)
  instaFollowerSnapshots InstaFollowerSnapshot[]
  automations            Automation[]
  forms                  Form[]

  @@index([userId])
  @@map("instagram_accounts")
}

model InstaFollowerSnapshot {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  instaAccountId String       @db.ObjectId
  instaAccount   InstaAccount @relation(fields: [instaAccountId], references: [id], onDelete: Cascade)

  followersCount Int
  date           DateTime // Stored in UTC, truncated to start of day (00:00:00)

  createdAt DateTime @default(now())

  // Ensure we only have 1 snapshot per account per day
  @@unique([instaAccountId, date])
  @@index([instaAccountId, date(sort: Desc)])
  @@map("insta_follower_snapshots")
}

// Embedded document for post-based automations
type PostTarget {
  id           String
  caption      String?
  mediaUrl     String?
  mediaType    String? // IMAGE | VIDEO
  thumbnailUrl String? // Only for VIDEO
  permalink    String?
  timestamp    String? // ISO timestamp
}

// Embedded document for story-based automations
// Snapshotted at creation — story media expires after 24h
type StoryTarget {
  id           String
  mediaUrl     String
  mediaType    String // IMAGE | VIDEO
  thumbnailUrl String? // Only for VIDEO
  caption      String?
  permalink    String
  timestamp    String // ISO timestamp
}

model Automation {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  instaAccountId String       @db.ObjectId
  instaAccount   InstaAccount @relation(fields: [instaAccountId], references: [id], onDelete: Cascade)

  triggerType    String       @default("COMMENT_ON_POST") // COMMENT_ON_POST | STORY_REPLY
  automationName String
  post           PostTarget?
  story          StoryTarget?
  targetId       String? // Computed field for indexing: postId, storyId, or 'account'
  targetType     String? // Computed field for indexing: post, story, or 'account'

  // Trigger configuration
  triggers           String[] // Keywords/phrases to match
  matchType          String   @default("CONTAINS") // CONTAINS, EXACT, REGEX
  // Action configuration
  actionType         String // DM | COMMENT_REPLY
  replyMessage       String // Fixed DM message
  replyImage         String? // Uploaded image URL for DM
  dmLinks            DmLink[] // Multiple links for DM
  commentReplyWhenDm String[] @default([]) // Multiple public replies — worker picks one randomly

  // Ask to Follow — gate applied before DM delivery
  askToFollowEnabled Boolean @default(false)
  askToFollowMessage String? // Message sent when commenter doesn't follow yet
  askToFollowLink    String? // Profile link appended to the Ask to Follow message

  // Opening Message
  openingMessageEnabled Boolean @default(true)
  openingMessage        String? // Message sent first (Ice-breaker)
  openingButtonText     String? // Text for the interactive button

  useVariables Boolean @default(true)

  status            String @default("ACTIVE") // ACTIVE, PAUSED, DELETED
  timesTriggered    Int    @default(0)
  triggersSignature String @default("")

  lastTriggeredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions AutomationExecution[]

  @@unique([instaAccountId, automationName, status])
  @@unique([instaAccountId, targetId, targetType, triggersSignature, status])
  @@index([instaAccountId, status])
  @@index([instaAccountId, triggerType, status])
  @@map("automations")
}

model AutomationExecution {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  automationId String     @db.ObjectId
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  // Trigger details (Unified for Comment/DM/Story)
  eventId        String
  eventText      String
  senderId       String
  senderUsername String

  // Execution details
  actionType         String // DM or COMMENT_REPLY
  sentMessage        String
  instagramMessageId String? // For tracking
  status             String // SUCCESS, FAILED, PENDING
  errorMessage       String?
  executedAt         DateTime @default(now())
  billed             Boolean  @default(false)

  @@unique([eventId, automationId])
  @@index([automationId, status])
  @@map("automation_executions")
}

model WebhookEvent {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  eventType       String // comment, message
  instagramUserId String
  payload         Json // Raw webhook payload
  processed       Boolean   @default(false)
  processedAt     DateTime?
  error           String?
  receivedAt      DateTime  @default(now())

  @@index([instagramUserId, processed])
  @@index([receivedAt])
  @@map("webhook_events")
}

// Option for dropdown/checkbox fields
type FormFieldOption {
  id    String
  label String
}

// One field stored inside a Form document
type FormFieldEntry {
  id          String
  type        String // text | number | email | url | phone | location | country | date | dropdown | checkbox | rating | upload
  label       String
  placeholder String?
  required    Boolean
  options     FormFieldOption[]
}

model Form {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  instaAccountId String       @db.ObjectId
  instaAccount   InstaAccount @relation(fields: [instaAccountId], references: [id], onDelete: Cascade)

  title       String
  description String           @default("")
  coverImage  String?
  fields      FormFieldEntry[]

  slug            String @unique // 8-char public URL slug
  status          String @default("DRAFT") // DRAFT | PUBLISHED
  submissionCount Int    @default(0)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]

  @@index([instaAccountId, status])
  @@map("forms")
}

model FormSubmission {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  formId String @db.ObjectId
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  // Keyed by field id — value is string or string[] (for checkbox)
  answers     Json
  submittedAt DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([formId, submittedAt(sort: Desc)])
  @@map("form_submissions")
}

type DmLink {
  title String
  url   String
}

// Tracks the user's current plan and billing period
model Subscription {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plan & status
  plan   String // FREE | BASIC | PREMIUM | BLACK
  status String // ACTIVE | EXPIRED | SOFT_PAUSED

  // Razorpay identifiers (null for FREE plan)
  razorpaySubscriptionId String?
  razorpayPlanId         String?

  // 28-day billing window (period=weekly, interval=4)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// Rolling credit counter per billing period
model CreditLedger {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  creditsUsed Int      @default(0)
  creditLimit Int // -1 = unlimited (Black plan)
  periodStart DateTime
  periodEnd   DateTime

  // Tracks whether the quota-full email has been sent this period
  quotaEmailSentAt    DateTime?
  quotaEmailSendingAt DateTime?

  updatedAt DateTime @updatedAt

  @@map("credit_ledgers")
}

// Idempotency store — prevents double-processing Razorpay webhook events
model ProcessedWebhookEvent {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  razorpayEventId String   @unique
  processedAt     DateTime @default(now())

  @@map("processed_webhook_events")
}
